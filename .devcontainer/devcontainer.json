{
  "name": "OpenClaw Free",
  "image": "node:22-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "postCreateCommand": "npm ci",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.vscode-typescript-next"
      ]
    }
  },
  "forwardPorts": [8080, 18789],
  "remoteUser": "node",
  "secrets": {
    "OPENROUTER_API_KEY": {
      "description": "OpenRouter API key (optional - free tier available)"
    },
    "NVIDIA_NIM_API_KEY": {
      "description": "NVIDIA NIM API key (optional - free at build.nvidia.com)"
    },
    "OPENCLAW_GATEWAY_TOKEN": {
      "description": "Gateway token (auto-generated if not set)"
    },
    "OPENCLAW_GATEWAY_PASSWORD": {
      "description": "Gateway password (alternative to token)"
    }
  }
}
