{
  "name": "OpenClaw",
  "image": "node:20-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "postCreateCommand": "npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.vscode-typescript-next",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },
  "forwardPorts": [3000, 3001],
  "workspaceMount": "source=${localWorkspaceFolder}/openclaw-workspace,target=/workspaces/openclaw,type=bind,consistency=cached",
  "remoteUser": "node"
}
